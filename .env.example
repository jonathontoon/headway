# Client ID of the GitHub OAuth App used for `login` (device flow).
# Create one at https://github.com/settings/developers and enable Device Flow.
VITE_GITHUB_CLIENT_ID=

# Worker-side settings (not read from this file):
# - Set GITHUB_CLIENT_ID (same value as above) as a Wrangler var so the
#   device-flow proxy only serves this app's client id.
# - Set GITHUB_CLIENT_SECRET via `wrangler secret put GITHUB_CLIENT_SECRET`
#   to let `disconnect` revoke the OAuth grant on GitHub.
